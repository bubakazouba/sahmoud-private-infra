# Copy to .env or export these in your shell before starting console + supervisor.
# All values below are required for the OAuth gate to work.

# Allowlist of Google email addresses permitted to access the dashboards.
# Comma-separated, no spaces.
ALLOWED_EMAILS=you@gmail.com,partner@gmail.com

# External HTTPS URL (Tailscale Funnel hostname etc.). Used as the OAuth
# redirect_uri base — must match the URL registered in Google Cloud Console.
PUBLIC_URL=https://your-host.tail-XXXX.ts.net

# Google OAuth web client. Path to client_secrets.json + the matching client_id.
OAUTH_CLIENT_SECRETS_FILE=./credentials/google_oauth_web.json
OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Optional — port the FastAPI control plane binds to. Default 8765.
# CONTROL_PORT=8765

# Optional — session-cookie signing key. If unset, a fresh one is generated to
# state/secret.key on first boot and reused on subsequent restarts.
# INFRA_SECRET_KEY=
